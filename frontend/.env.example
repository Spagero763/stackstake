# Copy to .env.local and adjust to point the frontend at a deployment.
# All variables are optional and fall back to the testnet defaults.

# Stacks address that deployed the contract.
VITE_DEPLOYER_ADDRESS=ST26TQH4FRPTKHQEYE6HZQG98R4CZE6PTJ8J1YYR8

# Contract name as published on chain.
VITE_CONTRACT_NAME=stacking-pool

# Target network: testnet or mainnet.
VITE_NETWORK=testnet
