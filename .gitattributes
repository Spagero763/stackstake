# Normalize line endings on checkin and force LF on checkout so the
# Clarinet toolchain (which rejects CRLF) works on every platform.
* text=auto eol=lf

*.clar  text eol=lf
*.toml  text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf

*.png   binary
*.jpg   binary
*.ico   binary
